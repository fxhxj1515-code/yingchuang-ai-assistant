{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "映创AI助手",
  "version": "2.7.4",
  "identifier": "com.yingchuang.ai-assistant",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "映创AI助手",
        "width": 1100,
        "height": 700,
        "minWidth": 400,
        "minHeight": 300,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval' data: blob:; connect-src * http: https:; img-src * data: blob:; media-src * data: blob:; font-src * data:; style-src 'self' 'unsafe-inline' *;"
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": true,
      "dangerousInsecure": true,
      "endpoints": ["https://i.hwzs.club/downloads/latest.json"],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../local-bridge/README.md": "local-bridge/",
      "../local-bridge/bridge.py": "local-bridge/"
    },
    "windows": {
      "wix": {
        "language": "zh-CN"
      }
    },
    "macOS": {
      "entitlements": "Entitlements.plist"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
